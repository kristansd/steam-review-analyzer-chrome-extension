{
  "manifest_version": 3,
  "name": "Steam Review Sentiment Analyzer",
  "version": "1.0",
  "description": "Fetches and analyzes Steam game reviews",

  "permissions": [
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "https://store.steampowered.com/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": ["content.js"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Steam Review Analyzer",
    "default_icon": {
      "16": "icon17.png",
      "48": "icon17.png",
      "128": "icon17.png"
    }
  },

  "icons": {
    "16": "icon17.png",
    "48": "icon17.png",
    "128": "icon17.png"
  }
}
